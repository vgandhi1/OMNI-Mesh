# =============================================================================
# RoboMesh — environment configuration
# Copy to `.env` and adjust as needed. None of these are required for the
# local-only demo; defaults work out of the box.
# =============================================================================

# Root directory that holds the local Iceberg warehouse, Bronze drops, and
# vector index. Defaults to ./data relative to the repo.
ROBOMESH_DATA_ROOT=./data

# Salt used by the HMAC-SHA256 masking pipeline (Phase 3).
# In production this MUST come from a secret manager (Vault, AWS SM, etc.).
# RoboMesh fails closed: if this is empty or matches any of the documented
# placeholder values, ``apply_dynamic_masking`` raises before writing any
# governed table. Generate a real salt with e.g. `openssl rand -hex 32`.
ROBOMESH_MASKING_SALT=

# Sentence-transformer model used for semantic embeddings (Phase 4).
ROBOMESH_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Number of synthetic episodes the generators emit per domain (Phase 0).
ROBOMESH_DEMO_EPISODES=24

# Random seed for reproducible demo data.
ROBOMESH_SEED=42

# Role used by the masking layer to decide whether to unmask values.
# One of: SECURITY_OPERATIONS, ML_RESEARCHER, HARDWARE_ENGINEER, ANALYST
ROBOMESH_ACTIVE_ROLE=ML_RESEARCHER
