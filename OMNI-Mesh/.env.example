# OMNI-Mesh runtime configuration. Copy to .env and set a real salt.
OMNI_MESH_PROFILE=ROBOTICS                      # ROBOTICS | MANUFACTURING | HEALTH_TECH
OMNI_MESH_MASKING_SALT=replace-with-a-strong-32char-secret
OMNI_MESH_DATA_ROOT=.omni_mesh
OMNI_MESH_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
OMNI_MESH_ACTIVE_ROLE=ML_RESEARCHER
OMNI_MESH_UNMASK_ROLE=SECURITY_OPERATIONS
