# =============================================================================
# HEAL-Mesh environment configuration
# Copy to `.env` and adjust values. NEVER commit `.env`.
# =============================================================================

# ----- Phase 1: Iceberg / Lakehouse -----
# Local REST/SQL catalog backed by SQLite for the demo. In production this would
# be Polaris / Tabular / AWS Glue / Unity Catalog.
HEAL_MESH_CATALOG_NAME=heal_mesh
HEAL_MESH_CATALOG_URI=sqlite:///./data/lakehouse/catalog.db
HEAL_MESH_WAREHOUSE_PATH=./data/lakehouse/warehouse

# ----- Phase 3: PHI cryptographic salt -----
# Real deployments must source this from a secret manager (AWS Secrets Manager,
# GCP Secret Manager, Vault). Never check the real value into version control.
HEAL_MESH_PHI_SALT=replace-me-with-a-secret-from-secret-manager

# ----- Phase 4: AI Readiness -----
HEAL_MESH_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HEAL_MESH_VECTOR_DB_PATH=./data/vector/chroma
# Optional - if blank the RAG agent falls back to a deterministic local responder.
OPENAI_API_KEY=

# ----- Phase 5: Observability -----
HEAL_MESH_OTEL_SERVICE_NAME=heal-mesh
HEAL_MESH_LOG_LEVEL=INFO
