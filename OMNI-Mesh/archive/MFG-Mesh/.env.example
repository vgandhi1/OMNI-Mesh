# MFG-Mesh runtime configuration. Copy this file to `.env` and fill in real values.

# Phase 5: fail-closed masking salt. MUST be set to a strong, non-default value
# at boot. The platform halts initialization if this is missing or matches the
# insecure default placeholder.
MFG_MESH_MASKING_SALT=replace-with-a-strong-random-secret

# Local warehouse / catalog paths (relative to the repo root by default).
MFG_MESH_WAREHOUSE_DIR=./.mfg_mesh/warehouse
MFG_MESH_CATALOG_DB=./.mfg_mesh/catalog.db
MFG_MESH_CHROMA_DIR=./.mfg_mesh/chroma

# Edge / streaming configuration.
MFG_MESH_FACILITIES=Texas_Giga_01,Berlin_Giga_02
MFG_MESH_LINES_PER_FACILITY=2
MFG_MESH_REGISTERS_PER_LINE=4
MFG_MESH_SIM_INTERVAL_MS=50

# Optional Kafka mode (off by default; demo writes straight to Iceberg).
MFG_MESH_KAFKA_ENABLED=false
MFG_MESH_KAFKA_BOOTSTRAP=localhost:9092
MFG_MESH_KAFKA_TOPIC=mfg.telemetry.raw

# Embedding model used by Phase 4 RAG. Kept small + local-friendly.
MFG_MESH_EMBEDDING_MODEL=all-MiniLM-L6-v2
MFG_MESH_EMBEDDING_DIM=384
